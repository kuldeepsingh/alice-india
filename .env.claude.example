# =====================================================
# Claude API Configuration
# =====================================================

# Claude API Key (get from https://console.anthropic.com/)
CLAUDE_API_KEY=sk-ant-YOUR_KEY_HERE

# Claude Model to use
# Options: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
# Recommended: claude-3-5-sonnet-20241022 (best value)
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Maximum tokens per request (response length)
# Higher = more detailed responses, but higher cost
CLAUDE_MAX_TOKENS=500

# Temperature (0.0 to 1.0)
# 0.0 = deterministic/analytical (good for trading)
# 1.0 = creative/varied (not suitable for trading)
CLAUDE_TEMPERATURE=0.3

# Timeout in milliseconds (how long to wait for response)
CLAUDE_TIMEOUT_MS=2000

# =====================================================
# Premium Feature Configuration
# =====================================================

# Enable/disable Claude features
CLAUDE_FEATURES_ENABLED=true

# Claude API credit limits per tier (monthly)
CLAUDE_CREDITS_FREE=0
CLAUDE_CREDITS_BASIC=50
CLAUDE_CREDITS_PREMIUM=500

# Cost per Claude request (in credits)
CLAUDE_CREDIT_COST=1

# =====================================================
# Feature Flags
# =====================================================

# Enable specific Claude features
FEATURE_CLAUDE_SIGNAL_VALIDATION=true
FEATURE_CLAUDE_SENTIMENT_ANALYSIS=true
FEATURE_CLAUDE_RISK_ASSESSMENT=true
FEATURE_CLAUDE_STRATEGY_REVIEW=true
FEATURE_CLAUDE_ANOMALY_DETECTION=true

# Rate limiting (requests per hour per user)
CLAUDE_RATE_LIMIT_BASIC=50
CLAUDE_RATE_LIMIT_PREMIUM=500
CLAUDE_RATE_LIMIT_ENTERPRISE=999999

# =====================================================
# Cache Configuration
# =====================================================

# Cache TTL for market context (seconds)
CACHE_MARKET_CONTEXT_TTL=300      # 5 minutes

# Cache TTL for sentiment analysis (seconds)
CACHE_SENTIMENT_TTL=300            # 5 minutes

# Cache TTL for user portfolio (seconds)
CACHE_PORTFOLIO_TTL=60             # 1 minute

# =====================================================
# Monitoring & Logging
# =====================================================

# Log all Claude API calls (for debugging)
CLAUDE_LOG_REQUESTS=true

# Send usage metrics to analytics
CLAUDE_TRACK_USAGE=true

# Daily budget in USD (set to 0 to disable)
CLAUDE_DAILY_BUDGET=10.00

